# Required: random string used to encrypt secrets in .alchemy/state at rest.
# Pick anything (e.g. `openssl rand -hex 32`) and store it in your password
# manager. Lose it and you'll have to re-enter every secret.
ALCHEMY_PASSWORD=

# Required: Exa API key for the web_search / web_scrape tools.
# https://exa.ai
EXA_API_KEY=

# Required once Cloudflare Access is in front of the Worker — see README.
# AUD tag from your Access app's Overview tab.
POLICY_AUD=
# Your Zero Trust team domain, e.g. https://yourteam.cloudflareaccess.com
TEAM_DOMAIN=

# Optional: defaults to Kimi 2.6 on Workers AI. Override to switch the
# default model — but per-agent provider selection (kimi / pi-local /
# pi-prod) happens in the UI, so most users won't change this.
MODEL_ID=@cf/moonshotai/kimi-k2.6

# Optional: only set if you've completed the ChatGPT subscription setup
# (see docs/pi-proxy-setup.md). Adds the VPC service binding to the deploy.
# PI_RELAY_VPC_SERVICE_ID=

# Note: there's no LOCAL_NOAUTH variable anymore. `vite dev` on localhost
# bypasses Cloudflare Access automatically via Vite's build-time DEV flag,
# and that branch is dead-code-eliminated from the production bundle.
