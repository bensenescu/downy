{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "downy",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/entry.worker.ts",
  "ai": {
    "binding": "AI",
  },
  "r2_buckets": [
    {
      "binding": "WORKSPACE_BUCKET",
      "bucket_name": "downy-workspace",
    },
  ],
  // D1 holds the agent registry (multi-agent metadata) and shared USER.md.
  // On a fresh clone:
  //   npx wrangler d1 create downy   # paste the returned id below
  //   pnpm run db:migrate:prod       # apply migrations to remote D1
  //   pnpm run db:migrate:local      # apply migrations for `wrangler dev`
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "downy",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID",
      "migrations_dir": "migrations",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "DownyAgent",
        "class_name": "DownyAgent",
      },
      {
        "name": "ChildAgent",
        "class_name": "ChildAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["OpenClawAgent"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ChildAgent"],
    },
    {
      "tag": "v3",
      "renamed_classes": [
        {
          "from": "OpenClawAgent",
          "to": "DownyAgent",
        },
      ],
    },
  ],
  // Cloudflare Access values — fill these in after you set up the Access
  // Application (see "Authentication: Cloudflare Access" in README.md).
  // Until then, the Worker rejects every request with 401.
  "vars": {
    "POLICY_AUD": "REPLACE_WITH_YOUR_ACCESS_AUD_TAG",
    "TEAM_DOMAIN": "https://REPLACE_WITH_YOUR_TEAM.cloudflareaccess.com",
    "MODEL_ID": "@cf/moonshotai/kimi-k2.6",
    // Used only when the `openrouter` provider is selected. Free-form
    // OpenRouter slug; change this + redeploy to switch models. The companion
    // secret OPENROUTER_API_KEY is set via `wrangler secret put` (prod) or
    // .dev.vars (local).
    "OPENROUTER_MODEL_ID": "anthropic/claude-sonnet-4-5",
  },
  // Optional: only needed if you're using the ChatGPT subscription path
  // (see docs/pi-proxy-setup.md). To enable, run `wrangler vpc service create`,
  // uncomment the block below, and paste in the returned service_id.
  //
  // vpc_services have no local emulation — `wrangler dev` tries to
  // provision a remote edge-preview Worker the moment the binding is
  // declared, which fails without prod entitlements. src/worker/agent/get-model.ts
  // reads the binding defensively, so when it's missing only the `pi-prod`
  // selection errors at turn time.
  // "vpc_services": [
  // 	{
  // 		"binding": "PI_RELAY_VPC",
  // 		"service_id": "REPLACE_WITH_YOUR_VPC_SERVICE_ID",
  // 	},
  // ],
}
